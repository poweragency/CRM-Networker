# Supabase project URL and anon (publishable) key.
# The frontend is RLS-bound and uses ONLY the anon key — never the service-role key.
# Copy this file to `.env.local` and fill in real values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# SERVER-ONLY service-role key (NEVER prefix with NEXT_PUBLIC — it must never reach
# the browser). Used only by the server-side admin client (lib/supabase/admin.ts)
# for privileged operations: creating/deleting member logins (account activation,
# tree removal). Required in production for the "add member with account" + invite
# flows to work — without it activation silently fails with `service_missing`.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Default org locale is Italian; only `it` is shipped in v1.
NEXT_PUBLIC_DEFAULT_LOCALE=it

# Demo opt-in. Leave UNSET. The mock/demo fallback (and its deterministic identity)
# is allowed only outside production OR when this is explicitly '1'. In production
# WITHOUT Supabase env the app fails closed (redirects to login) instead of serving
# a fake admin shell — so never set this in a real deployment.
# NEXT_PUBLIC_DEMO=1
