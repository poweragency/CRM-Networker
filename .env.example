# =============================================================================
# .env.example — CRM Networker
# Copy to `.env.local` (Next.js) and fill in real values. NEVER commit .env.local.
#
# Local dev: run `npx supabase start` and copy the URL + keys it prints.
# Hosted:    find these under Supabase Dashboard -> Project Settings -> API.
# =============================================================================

# -----------------------------------------------------------------------------
# Public (browser-exposed) — safe to ship to the client. The anon key is
# RLS-bound: it can only ever read/write what Row-Level Security permits for the
# authenticated user. NEXT_PUBLIC_* vars are inlined into the client bundle.
# -----------------------------------------------------------------------------
# Project API URL.
#   local:  http://127.0.0.1:54321
#   hosted: https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anonymous key (RLS-enforced). Used by the supabase-js browser client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Server-only — NEVER expose to the browser, NEVER prefix with NEXT_PUBLIC_.
# The service-role key BYPASSES Row-Level Security. Use it ONLY in trusted
# server contexts (Edge Functions / server actions) and only through functions
# that re-assert org scope + can_see_marketer() (doc 07 §6.4 service-role
# fencing). Leaking this key compromises every tenant.
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
